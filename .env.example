# CleanChain Blockchain Configuration
# Copy this file to .env and fill in your values

# Polygon Amoy Testnet RPC URL
# Get one from https://www.alchemy.com/ or https://www.infura.io/
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY

# Private key of the wallet that will deploy contracts and perform admin actions
# WARNING: Never commit this to version control!
PRIVATE_KEY=0xYourPrivateKeyHere

# Optional: Custom gas price (in wei)
# GAS_PRICE=50000000000

# Optional: Etherscan/Polygonscan API key for contract verification
# POLYGONSCAN_API_KEY=YourApiKeyToken
